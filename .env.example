# vwap API Configuration
# Copy to .env and fill in your values. NEVER commit .env to git.
#
# Env keys match config keys: app_config.* → APP_CONFIG_* (dots → underscores, upper case).
# Example: app_config.ethereum.rpc_url → APP_CONFIG_ETHEREUM_RPC_URL

# =============================================================================
# Application
# =============================================================================

# Environment (config file suffix: local, staging, production)
ENV=local

# Log level: DEBUG, INFO, WARN, ERROR
LOG_LEVEL=INFO

# =============================================================================
# HTTP (app_config.http)
# =============================================================================

APP_CONFIG_HTTP_ADDR=127.0.0.1:8080
# APP_CONFIG_HTTP_READ_TIMEOUT=5s
# APP_CONFIG_HTTP_WRITE_TIMEOUT=10s

# =============================================================================
# PostgreSQL (app_config.postgresql)
# =============================================================================

APP_CONFIG_POSTGRESQL_HOST=127.0.0.1
APP_CONFIG_POSTGRESQL_PORT=5432
APP_CONFIG_POSTGRESQL_DATABASE=vwap
APP_CONFIG_POSTGRESQL_USER=postgres
APP_CONFIG_POSTGRESQL_PASSWORD=postgres

# =============================================================================
# Redis (app_config.redis) — if used
# =============================================================================

APP_CONFIG_REDIS_HOST=127.0.0.1
APP_CONFIG_REDIS_PORT=6379
APP_CONFIG_REDIS_PASSWORD=
APP_CONFIG_REDIS_DB=0

# =============================================================================
# Ethereum (app_config.ethereum)
# =============================================================================

# RPC URL (required for indexer and vault; orderbook/trades API works without if use_mock=true)
# Examples: https://eth.llamarpc.com, https://mainnet.base.org, https://sepolia.base.org
APP_CONFIG_ETHEREUM_RPC_URL=https://eth.llamarpc.com

# Chain ID (required for orderbook EIP-712 when vwap_rfq_contract_addr is set)
# 1=Ethereum, 8453=Base, 11155111=Sepolia, 84532=Base Sepolia
APP_CONFIG_ETHEREUM_CHAIN_ID=1

# VWAP RFQ Spot contract address (orderbook create/expire + indexer)
# Leave empty to disable POST/GET orders and indexer; set to enable.
APP_CONFIG_ETHEREUM_VWAP_RFQ_CONTRACT_ADDR=

# StateView contract address (liquidity / vault features)
APP_CONFIG_ETHEREUM_STATEVIEW_CONTRACT_ADDR=0x7ffe42c4a5deea5b0fec41c94c136cf115597227

# Use mock for liquidity (no RPC for liquidity); indexer/orderbook still need real RPC when contract addr set
APP_CONFIG_ETHEREUM_USE_MOCK=false
