# =============================================================================
# Ethereum Network Overrides
# Copy to .env and fill in your values for custom networks (e.g. Tenderly VTN).
# These will override the defaults in config/api/base.yaml.
# =============================================================================

# RPC URL (required for indexer; orderbook/trades API works without if use_mock=true)
# For Tenderly VTN: use the VTN public RPC URL from the Tenderly dashboard.
# APP_CONFIG_ETHEREUM_RPC_URL=https://virtual.sepolia.eu.rpc.tenderly.co/...

# Chain ID (required for orderbook EIP-712 when vwap_rfq_contract_addr is set)
# APP_CONFIG_ETHEREUM_CHAIN_ID=11155111

# VWAP RFQ Spot contract address (orderbook create/expire + indexer)
# APP_CONFIG_ETHEREUM_VWAP_RFQ_CONTRACT_ADDR=0x...

# Indexer start block — lower bound for historical scanning.
# 0 (default): start from the current latest block, only watch future events.
# Non-zero: scan from this block forward to pick up historical fills/settlements.
# For Tenderly VTN: set to the block just before the first fill tx (printed by demo-vtn.sh).
# APP_CONFIG_ETHEREUM_INDEXER_START_BLOCK=0
